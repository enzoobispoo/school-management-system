  schoolId    String
  avaliacaoId String
  matriculaId String
  nota        Decimal  @db.Decimal(5, 2)
  observacao  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  avaliacao Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  matricula Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  @@unique([avaliacaoId, matriculaId])
  @@index([schoolId])
  @@index([matriculaId])
}

model AulaRegistro {
  id           String    @id @default(cuid())
  schoolId     String
  turmaId      String
  disciplinaId String
  titulo       String?
  conteudo     String?
  dataAula     DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turma      Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina Disciplina  @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  presencas  PresencaAula[]

  @@index([schoolId])
  @@index([turmaId])
  @@index([disciplinaId])
  @@index([dataAula])
}

model PresencaAula {
