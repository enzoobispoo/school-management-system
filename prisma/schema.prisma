generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id        String   @id @default(cuid())
  nome      String
  slug      String   @unique
  email     String?
  plano     String   @default("starter")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  alunos         Aluno[]
  cursos         Curso[]
  professores    Professor[]
  turmas         Turma[]
  disciplinas    Disciplina[]
  matriculas     Matricula[]
  pagamentos     Pagamento[]
  eventos        Evento[]
  notificacoes   Notificacao[]
  userInvites    UserInvite[]
  escolaSettings EscolaSettings?
  subscriptions  SchoolSubscription[]
  financeAuditEvents FinanceAuditEvent[]
  turmaDisciplinas TurmaDisciplina[]
  avaliacoes       Avaliacao[]
  notasAvaliacao   NotaAvaliacao[]
  aulasRegistro    AulaRegistro[]
  presencasAula    PresencaAula[]
  alunoRegistros         AlunoRegistro[]
  operationalIncidents    OperationalIncident[]
  operationalPlaybookRuns OperationalPlaybookRun[]
  materiaisDidaticos      MaterialDidatico[]
  trocaProfessorPropostas TrocaProfessorProposta[]
  schoolChatThreads       SchoolChatThread[]
  docenteDashboardConfigs DocenteDashboardConfig[]
  avaliacoesQuestoes      AvaliacaoQuestao[]
  avaliacoesAlternativas  AvaliacaoAlternativa[]
  jogoSessoes             JogoSessao[]
  jogoParticipantes       JogoParticipante[]
  jogoRespostas           JogoResposta[]

  @@index([slug])
  @@index([ativo])
}

model Plan {
  id             String   @id @default(cuid())
  nome           String   @unique
  slug           String   @unique
  preco          Decimal  @db.Decimal(10, 2)
  descricao      String?
  limiteAlunos   Int?
  limiteTurmas   Int?
  limiteUsuarios Int?
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions SchoolSubscription[]

  @@index([slug])
  @@index([ativo])
}

model SchoolSubscription {
  id          String             @id @default(cuid())
  schoolId    String
  planId      String
  status      SubscriptionStatus @default(ATIVA)
  valorPago   Decimal            @db.Decimal(10, 2)
  dataInicio  DateTime           @default(now())
  dataFim     DateTime?
  observacoes String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([schoolId])
  @@index([planId])
  @@index([status])
  @@index([dataInicio])
}

enum SubscriptionStatus {
  ATIVA
  CANCELADA
  SUSPENSA
  TRIAL
}

model Aluno {
  id                  String      @id @default(cuid())
  schoolId            String
  nome                String
  email               String?
  telefone            String?
  dataNascimento      DateTime?
  endereco            String?
  status              StatusAluno @default(ATIVO)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  cpf                 String?
  responsavelNome     String?
  responsavelTelefone String?
  responsavelEmail    String?
  responsavelCpf      String?
  possuiLaudo         Boolean     @default(false)
  laudoDescricao      String?
  laudoCid            String?
  laudoTipo           String?
  laudoNivel          String?
  laudoProfissional   String?
  laudoData           DateTime?
  alergias            String?
  medicamentos        String?
  condicoesCronicas   String?
  planoSaude          String?
  contatoEmergenciaNome     String?
  contatoEmergenciaTelefone String?
  adaptacaoNecessaria Boolean     @default(false)
  adaptacaoDescricao  String?
  observacoesMedicas  String?
  observacoesProf     String?
  tratamentos         String?
  fotoUrl             String?
  observacoesGerais   String?
  indicacao           String?
  dataSaida           DateTime?
  motivoSaida         String?
  nivelInicial        String?
  idiomaNativo        String?
  asaasCustomerId     String?

  school          School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  documentos      AlunoDocumento[]
  statusHistorico AlunoStatusHistorico[]
  matriculas      Matricula[]
  registros       AlunoRegistro[]

  @@unique([schoolId, email])
  @@unique([schoolId, cpf])
  @@index([schoolId])
  @@index([nome])
  @@index([status])
}

model Curso {
  id           String           @id @default(cuid())
  schoolId     String
  nome         String
  categoria    String
  descricao    String?
  duracaoTexto String?
  valorMensal  Decimal          @db.Decimal(10, 2)
  ativo        Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  eventos     Evento[]
  turmas      Turma[]
  professores ProfessorCurso[]

  @@unique([schoolId, nome])
  @@index([schoolId])
  @@index([categoria])
  @@index([ativo])
}

model Professor {
  id       String  @id @default(cuid())
  schoolId String
  nome     String
  email    String?
  telefone String?
  ativo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school          School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  eventos         Evento[]
  turmas          Turma[]
  cursos          ProfessorCurso[]
  historicoTurmas TurmaProfessorHistorico[]
  avaliacoes       Avaliacao[]
  linkedUser       User?
  materiaisDidaticos MaterialDidatico[]
  registrosPedagogicos AlunoRegistro[]
  notificacoesDirigidas Notificacao[]
  trocaPropostasRecebidas TrocaProfessorProposta[] @relation("TrocaProfessorAlvo")
  trocaPropostasComoSaida TrocaProfessorProposta[] @relation("TrocaProfessorAnterior")

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([nome])
  @@index([ativo])
}

model Turma {
  id               String   @id @default(cuid())
  schoolId         String
  cursoId          String
  professorId      String
  nome             String
  capacidadeMaxima Int
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school               School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curso                Curso                     @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  professor            Professor                 @relation(fields: [professorId], references: [id])
  eventos              Evento[]
  matriculas           Matricula[]
  horarios             TurmaHorario[]
  historicoProfessores TurmaProfessorHistorico[]
  disciplinas         TurmaDisciplina[]
  avaliacoes              Avaliacao[]
  aulas                   AulaRegistro[]
  materiaisDidaticos      MaterialDidatico[]
  trocaProfessorPropostas TrocaProfessorProposta[]

  @@unique([schoolId, cursoId, nome])
  @@index([schoolId])
  @@index([cursoId])
  @@index([professorId])
  @@index([ativo])
}

model TurmaHorario {
  id         String    @id @default(cuid())
  turmaId    String
  diaSemana  DiaSemana
  horaInicio String
  horaFim    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  turma      Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@index([turmaId])
  @@index([diaSemana])
}

model Matricula {
  id                   String          @id @default(cuid())
  schoolId             String
  alunoId              String
  turmaId              String
  dataMatricula        DateTime        @default(now())
  /// Dia do mês (1–31) para vencimento das mensalidades desta matrícula; meses curtos são ajustados ao último dia.
  diaVencimentoMensal   Int?
  dataCancelamento   DateTime?
  motivoCancelamento String?
  observacoes        String?
  status             StatusMatricula @default(ATIVA)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  aluno      Aluno      @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  turma      Turma      @relation(fields: [turmaId], references: [id])
  pagamentos Pagamento[]
  notas      NotaAvaliacao[]
  presencas  PresencaAula[]

  @@index([schoolId])
  @@index([alunoId])
  @@index([turmaId])
  @@index([status])
  @@index([dataMatricula])
}

model Pagamento {
  id              String          @id @default(cuid())
  schoolId        String
  matriculaId     String
  competenciaMes  Int
  competenciaAno  Int
  descricao       String
  valor           Decimal         @db.Decimal(10, 2)
  vencimento      DateTime
  dataPagamento   DateTime?
  status          StatusPagamento @default(PENDENTE)
  metodoPagamento String?
  observacoes     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  billingProvider     String?
  billingChargeType   String?
  billingExternalId   String?
  billingInvoiceUrl   String?
  billingBankSlipUrl  String?
  billingPixQrCode    String?
  billingPixCopyPaste String?
  billingStatus       String?
  boletoGeradoEm      DateTime?
  cobrancaLoteId      String?
  ultimoLembreteEnviadoEm DateTime?

  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  matricula Matricula     @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  envios    CobrancaEnvio[]

  @@unique([matriculaId, competenciaMes, competenciaAno])
  @@index([schoolId])
  @@index([matriculaId])
  @@index([status])
  @@index([vencimento])
  @@index([competenciaAno, competenciaMes])
  @@index([schoolId, status, dataPagamento])
}

model CobrancaLote {
  id          String   @id @default(cuid())
  alunoId     String
  provider    String?
  externalId  String?
  invoiceUrl  String?
  bankSlipUrl String?
  status      String?
  valorTotal  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CobrancaEnvio {
  id             String              @id @default(cuid())
  pagamentoId    String?
  cobrancaLoteId String?
  canal          CanalCobranca
  tipo           TipoEnvioCobranca
  destino        String
  status         StatusEnvioCobranca @default(PENDENTE)
  provedor       String?
  externalId     String?
  mensagem       String?
  erro           String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  pagamento Pagamento? @relation(fields: [pagamentoId], references: [id], onDelete: SetNull)

  @@index([pagamentoId])
  @@index([cobrancaLoteId])
  @@index([canal])
  @@index([tipo])
  @@index([status])
  @@index([createdAt])
}

enum CanalCobranca {
  WHATSAPP
  EMAIL
  SMS
  SISTEMA
}

enum TipoEnvioCobranca {
  BOLETO
  LEMBRETE
  COBRANCA_ATRASO
}

enum StatusEnvioCobranca {
  PENDENTE
  ENVIADO
  FALHO
}

model Evento {
  id          String       @id @default(cuid())
  schoolId    String
  titulo      String
  descricao   String?
  tipo        TipoEvento   @default(GERAL)
  dataInicio  DateTime
  dataFim     DateTime
  diaInteiro  Boolean      @default(false)
  cor         String?
  local       String?
  professorId String?
  turmaId     String?
  cursoId     String?
  ativo       Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  origem      OrigemEvento @default(MANUAL)

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curso     Curso?     @relation(fields: [cursoId], references: [id])
  professor Professor? @relation(fields: [professorId], references: [id])
  turma     Turma?     @relation(fields: [turmaId], references: [id])

  @@index([schoolId])
  @@index([tipo])
  @@index([origem])
  @@index([ativo])
  @@index([dataInicio])
  @@index([dataFim])
  @@index([professorId])
  @@index([turmaId])
  @@index([cursoId])
}

model Notificacao {
  id           String              @id @default(cuid())
  schoolId     String
  tipo         TipoNotificacao
  titulo       String
  mensagem     String
  lida         Boolean             @default(false)
  entidadeTipo EntidadeNotificacao @default(SISTEMA)
  entidadeId   String?
  /** Se preenchido, apenas esse professor (conta vinculada) deve ver na área do docente. */
  destinatarioProfessorId String?
  /** Se preenchido, só esse usuário vê (ex.: alerta de mensagem no chat escolar). */
  destinatarioUserId String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  school                School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  destinatarioProfessor Professor? @relation(fields: [destinatarioProfessorId], references: [id], onDelete: SetNull)
  destinatarioUser    User?      @relation("NotificacaoParaUsuario", fields: [destinatarioUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([tipo])
  @@index([lida])
  @@index([createdAt])
  @@index([entidadeTipo, entidadeId])
  @@index([destinatarioProfessorId])
  @@index([destinatarioUserId])
}

model User {
  id                         String    @id @default(cuid())
  schoolId                   String?
  email                      String    @unique
  openaiApiKey               String?
  plan                       String    @default("starter")
  aiUsage                    Int       @default(0)
  createdAt                  DateTime  @default(now())
  ativo                      Boolean   @default(true)
  lastLoginAt                DateTime?
  nome                       String
  passwordHash               String
  role                       UserRole  @default(ADMIN)
  updatedAt                  DateTime  @updatedAt
  username                   String?   @unique
  densidade                  String?   @default("comfortable")
  telefone                   String?
  temaPreferido              String?   @default("light")
  /** URL pública da foto de perfil (mensagens, cabeçalhos). */
  avatarUrl                  String?
  dashboardCards             Json?
  dashboardCardsOrder        Json?
  dashboardInsightsFrequency String?   @default("weekly")
  dashboardInsightsDismissed Json?
  dashboardInsightsEnabled   Boolean   @default(true)
  dashboardInsightsLimit     Int       @default(3)

  school         School?         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  aiAuditLogs    AiAuditLog[]
  aiChatSessions AiChatSession[]
  professorId    String?    @unique
  professor      Professor? @relation(fields: [professorId], references: [id], onDelete: SetNull)

  schoolChatParticipants SchoolChatParticipant[]
  schoolChatMessagesSent SchoolChatMessage[]    @relation("SchoolChatMessageSender")
  schoolChatGroupsOwned  SchoolChatThread[]     @relation("SchoolChatThreadOwner")
  notificacoesRecebidas  Notificacao[]          @relation("NotificacaoParaUsuario")

  @@index([schoolId])
  @@index([email])
  @@index([username])
  @@index([role])
  @@index([ativo])
}

model ProfessorCurso {
  id          String   @id @default(cuid())
  professorId String
  cursoId     String
  createdAt   DateTime @default(now())

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  curso     Curso     @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@unique([professorId, cursoId])
  @@index([professorId])
  @@index([cursoId])
}

model TurmaProfessorHistorico {
  id          String    @id @default(cuid())
  turmaId     String
  professorId String
  dataInicio  DateTime
  dataFim     DateTime?
  motivoTroca String?
  observacoes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  turma     Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  professor Professor @relation(fields: [professorId], references: [id], onDelete: Restrict)

  @@index([turmaId])
  @@index([professorId])
  @@index([dataInicio])
  @@index([dataFim])
}

model TrocaProfessorProposta {
  id                  String                       @id @default(cuid())
  schoolId            String
  turmaId             String
  professorAnteriorId String
  professorAlvoId     String
  motivoTroca         String?
  observacoes         String?
  dataInicioPrevista  DateTime
  resumoTurma         String?
  resumoHorarios      String?
  status              TrocaProfessorPropostaStatus @default(PENDENTE)
  respondidoEm        DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  school            School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turma             Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  professorAnterior Professor @relation("TrocaProfessorAnterior", fields: [professorAnteriorId], references: [id], onDelete: Restrict)
  professorAlvo     Professor @relation("TrocaProfessorAlvo", fields: [professorAlvoId], references: [id], onDelete: Restrict)

  @@index([schoolId])
  @@index([turmaId])
  @@index([professorAlvoId, status])
  @@index([status])
}

model DocenteDashboardConfig {
  id                    String   @id @default(cuid())
  schoolId              String
  role                  UserRole @default(PROFESSOR)
  minAttendancePercent  Int      @default(75)
  minAttendanceSamples  Int      @default(4)
  minGrade              Decimal  @default(6.0) @db.Decimal(4, 2)
  minGradeSamples       Int      @default(2)
  weeklyCallsTarget     Int?
  weeklyAssessmentsTarget Int?
  weeklyGradesTarget    Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, role])
  @@index([schoolId])
}

model SystemSetting {
  id             String         @id @default("default")
  aiProviderMode AiProviderMode @default(PLATFORM)
  openaiApiKey   String?
  aiMonthlyLimit Int            @default(1000)
  aiUsageCount   Int            @default(0)
  aiUsageResetAt DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model UserInvite {
  id        String    @id @default(cuid())
  schoolId  String?
  email     String
  role      UserRole  @default(SECRETARIA)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model AiAuditLog {
  id             String   @id @default(cuid())
  userId         String
  schoolId       String?
  correlationId  String?
  message        String
  intent         String
  response       String
  executed       Boolean  @default(false)
  /** Resumo das invocações de tools (nome, duração, erro opcional). */
  toolRuns       Json?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId])
  @@index([correlationId])
  @@index([intent])
  @@index([createdAt])
}

model AiChatSession {
  id        String          @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  AiChatMessage[]
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AiChatMessage {
  id         String          @id @default(cuid())
  sessionId  String
  role       ChatMessageRole
  content    String
  intent     String?
  confidence Float?
  executed   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  session    AiChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model FinanceAuditEvent {
  id          String   @id @default(cuid())
  schoolId    String
  eventType   String
  source      String
  status      String
  referenceId String?
  message     String
  payload     Json?
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([eventType])
  @@index([source])
  @@index([status])
  @@index([createdAt])
}

model Disciplina {
  id        String   @id @default(cuid())
  schoolId  String
  nome      String
  codigo    String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turmas              TurmaDisciplina[]
  avaliacoes          Avaliacao[]
  aulas               AulaRegistro[]
  materiaisDidaticos  MaterialDidatico[]

  @@unique([schoolId, nome])
  @@index([schoolId])
  @@index([ativo])
}

model TurmaDisciplina {
  id           String   @id @default(cuid())
  schoolId     String
  turmaId      String
  disciplinaId String
  createdAt    DateTime @default(now())

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turma      Turma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@unique([turmaId, disciplinaId])
  @@index([schoolId])
  @@index([turmaId])
  @@index([disciplinaId])
}

model Avaliacao {
  id           String   @id @default(cuid())
  schoolId     String
  turmaId      String
  disciplinaId String
  professorId  String?
  formato      FormatoAvaliacao @default(CLASSICA)
  titulo       String
  descricao    String?
  peso         Decimal? @db.Decimal(5, 2)
  dataAvaliacao DateTime
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turma      Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina Disciplina  @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  professor  Professor?  @relation(fields: [professorId], references: [id], onDelete: SetNull)
  notas      NotaAvaliacao[]
  questoes   AvaliacaoQuestao[]
  jogoSessoes JogoSessao[]

  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@index([turmaId])
  @@index([disciplinaId])
  @@index([dataAvaliacao])
}

model AvaliacaoQuestao {
  id          String   @id @default(cuid())
  schoolId    String
  avaliacaoId String
  ordem       Int
  enunciado   String
  explicacao  String?
  pontos      Decimal? @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  avaliacao   Avaliacao  @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  alternativas AvaliacaoAlternativa[]
  respostas    JogoResposta[]

  @@index([schoolId])
  @@index([avaliacaoId, ordem])
}

model AvaliacaoAlternativa {
  id          String   @id @default(cuid())
  schoolId    String
  questaoId   String
  ordem       Int
  texto       String
  correta     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  questao     AvaliacaoQuestao  @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  respostas   JogoResposta[]

  @@index([schoolId])
  @@index([questaoId, ordem])
}

model JogoSessao {
  id                       String           @id @default(cuid())
  schoolId                 String
  avaliacaoId              String
  pin                      String           @unique
  status                   JogoSessaoStatus @default(LOBBY)
  questaoAtualOrdem        Int              @default(1)
  tempoPorQuestaoSegundos  Int?
  questaoDeadlineAt        DateTime?
  createdByProfessorId     String?
  startedAt                DateTime?
  finishedAt               DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  school                School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
