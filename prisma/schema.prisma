generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id        String   @id @default(cuid())
  nome      String
  slug      String   @unique
  email     String?
  plano     String   @default("starter")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  alunos         Aluno[]
  cursos         Curso[]
  professores    Professor[]
  turmas         Turma[]
  disciplinas    Disciplina[]
  matriculas     Matricula[]
  pagamentos     Pagamento[]
  eventos        Evento[]
  notificacoes   Notificacao[]
  userInvites    UserInvite[]
  escolaSettings EscolaSettings?
  subscriptions  SchoolSubscription[]
  financeAuditEvents FinanceAuditEvent[]
  turmaDisciplinas TurmaDisciplina[]
  avaliacoes       Avaliacao[]
  notasAvaliacao   NotaAvaliacao[]
  aulasRegistro    AulaRegistro[]
  presencasAula    PresencaAula[]
  alunoRegistros         AlunoRegistro[]
  operationalIncidents    OperationalIncident[]
  operationalPlaybookRuns OperationalPlaybookRun[]

  @@index([slug])
  @@index([ativo])
}

model Plan {
  id             String   @id @default(cuid())
  nome           String   @unique
  slug           String   @unique
  preco          Decimal  @db.Decimal(10, 2)
  descricao      String?
  limiteAlunos   Int?
  limiteTurmas   Int?
  limiteUsuarios Int?
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions SchoolSubscription[]

  @@index([slug])
  @@index([ativo])
}

model SchoolSubscription {
  id          String             @id @default(cuid())
  schoolId    String
  planId      String
  status      SubscriptionStatus @default(ATIVA)
  valorPago   Decimal            @db.Decimal(10, 2)
  dataInicio  DateTime           @default(now())
  dataFim     DateTime?
  observacoes String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([schoolId])
  @@index([planId])
  @@index([status])
  @@index([dataInicio])
}

enum SubscriptionStatus {
  ATIVA
  CANCELADA
  SUSPENSA
  TRIAL
}

model Aluno {
  id                  String      @id @default(cuid())
  schoolId            String
  nome                String
  email               String?
  telefone            String?
  dataNascimento      DateTime?
  endereco            String?
  status              StatusAluno @default(ATIVO)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  cpf                 String?
  responsavelNome     String?
  responsavelTelefone String?
  responsavelEmail    String?
  responsavelCpf      String?
  possuiLaudo         Boolean     @default(false)
  laudoDescricao      String?
  laudoCid            String?
  laudoTipo           String?
  laudoNivel          String?
  laudoProfissional   String?
  laudoData           DateTime?
  alergias            String?
  medicamentos        String?
  condicoesCronicas   String?
  planoSaude          String?
  contatoEmergenciaNome     String?
  contatoEmergenciaTelefone String?
  adaptacaoNecessaria Boolean     @default(false)
  adaptacaoDescricao  String?
  observacoesMedicas  String?
  observacoesProf     String?
  tratamentos         String?
  fotoUrl             String?
  observacoesGerais   String?
  indicacao           String?
  dataSaida           DateTime?
  motivoSaida         String?
  nivelInicial        String?
  idiomaNativo        String?
  asaasCustomerId     String?

  school          School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  documentos      AlunoDocumento[]
  statusHistorico AlunoStatusHistorico[]
  matriculas      Matricula[]
  registros       AlunoRegistro[]

  @@unique([schoolId, email])
  @@unique([schoolId, cpf])
  @@index([schoolId])
  @@index([nome])
  @@index([status])
}

model Curso {
  id           String           @id @default(cuid())
  schoolId     String
  nome         String
  categoria    String
  descricao    String?
  duracaoTexto String?
  valorMensal  Decimal          @db.Decimal(10, 2)
  ativo        Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  eventos     Evento[]
  turmas      Turma[]
  professores ProfessorCurso[]

  @@unique([schoolId, nome])
  @@index([schoolId])
  @@index([categoria])
  @@index([ativo])
}

model Professor {
  id       String  @id @default(cuid())
  schoolId String
  nome     String
  email    String?
  telefone String?
  ativo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school          School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  eventos         Evento[]
  turmas          Turma[]
  cursos          ProfessorCurso[]
  historicoTurmas TurmaProfessorHistorico[]
  avaliacoes      Avaliacao[]

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([nome])
  @@index([ativo])
}

model Turma {
  id               String   @id @default(cuid())
  schoolId         String
  cursoId          String
  professorId      String
  nome             String
  capacidadeMaxima Int
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school               School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curso                Curso                     @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  professor            Professor                 @relation(fields: [professorId], references: [id])
  eventos              Evento[]
  matriculas           Matricula[]
  horarios             TurmaHorario[]
  historicoProfessores TurmaProfessorHistorico[]
  disciplinas         TurmaDisciplina[]
  avaliacoes          Avaliacao[]
  aulas               AulaRegistro[]

  @@unique([schoolId, cursoId, nome])
  @@index([schoolId])
  @@index([cursoId])
  @@index([professorId])
  @@index([ativo])
}

model TurmaHorario {
  id         String    @id @default(cuid())
  turmaId    String
  diaSemana  DiaSemana
  horaInicio String
  horaFim    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  turma      Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@index([turmaId])
  @@index([diaSemana])
}

model Matricula {
  id                 String          @id @default(cuid())
  schoolId           String
  alunoId            String
  turmaId            String
  dataMatricula      DateTime        @default(now())
  dataCancelamento   DateTime?
  motivoCancelamento String?
  observacoes        String?
  status             StatusMatricula @default(ATIVA)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  aluno      Aluno      @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  turma      Turma      @relation(fields: [turmaId], references: [id])
  pagamentos Pagamento[]
  notas      NotaAvaliacao[]
  presencas  PresencaAula[]

  @@index([schoolId])
  @@index([alunoId])
  @@index([turmaId])
  @@index([status])
  @@index([dataMatricula])
}

model Pagamento {
  id              String          @id @default(cuid())
  schoolId        String
  matriculaId     String
  competenciaMes  Int
  competenciaAno  Int
  descricao       String
  valor           Decimal         @db.Decimal(10, 2)
  vencimento      DateTime
  dataPagamento   DateTime?
  status          StatusPagamento @default(PENDENTE)
  metodoPagamento String?
  observacoes     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  billingProvider     String?
  billingChargeType   String?
  billingExternalId   String?
  billingInvoiceUrl   String?
  billingBankSlipUrl  String?
  billingPixQrCode    String?
  billingPixCopyPaste String?
  billingStatus       String?
  boletoGeradoEm      DateTime?
  cobrancaLoteId      String?
  ultimoLembreteEnviadoEm DateTime?

  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  matricula Matricula     @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  envios    CobrancaEnvio[]

  @@unique([matriculaId, competenciaMes, competenciaAno])
  @@index([schoolId])
  @@index([matriculaId])
  @@index([status])
  @@index([vencimento])
  @@index([competenciaAno, competenciaMes])
}

model CobrancaLote {
  id          String   @id @default(cuid())
  alunoId     String
  provider    String?
  externalId  String?
  invoiceUrl  String?
  bankSlipUrl String?
  status      String?
  valorTotal  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CobrancaEnvio {
  id             String              @id @default(cuid())
  pagamentoId    String?
  cobrancaLoteId String?
  canal          CanalCobranca
  tipo           TipoEnvioCobranca
  destino        String
  status         StatusEnvioCobranca @default(PENDENTE)
  provedor       String?
  externalId     String?
  mensagem       String?
  erro           String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  pagamento Pagamento? @relation(fields: [pagamentoId], references: [id], onDelete: SetNull)

  @@index([pagamentoId])
  @@index([cobrancaLoteId])
  @@index([canal])
  @@index([tipo])
  @@index([status])
  @@index([createdAt])
}

enum CanalCobranca {
  WHATSAPP
  EMAIL
  SMS
  SISTEMA
}

enum TipoEnvioCobranca {
  BOLETO
  LEMBRETE
  COBRANCA_ATRASO
}

enum StatusEnvioCobranca {
  PENDENTE
  ENVIADO
  FALHO
}

model Evento {
  id          String       @id @default(cuid())
  schoolId    String
  titulo      String
  descricao   String?
  tipo        TipoEvento   @default(GERAL)
  dataInicio  DateTime
  dataFim     DateTime
  diaInteiro  Boolean      @default(false)
  cor         String?
  local       String?
  professorId String?
  turmaId     String?
  cursoId     String?
  ativo       Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  origem      OrigemEvento @default(MANUAL)

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curso     Curso?     @relation(fields: [cursoId], references: [id])
  professor Professor? @relation(fields: [professorId], references: [id])
  turma     Turma?     @relation(fields: [turmaId], references: [id])

  @@index([schoolId])
  @@index([tipo])
  @@index([origem])
  @@index([ativo])
  @@index([dataInicio])
  @@index([dataFim])
  @@index([professorId])
  @@index([turmaId])
  @@index([cursoId])
}

model Notificacao {
  id           String              @id @default(cuid())
  schoolId     String
  tipo         TipoNotificacao
  titulo       String
  mensagem     String
  lida         Boolean             @default(false)
  entidadeTipo EntidadeNotificacao @default(SISTEMA)
  entidadeId   String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([tipo])
  @@index([lida])
  @@index([createdAt])
  @@index([entidadeTipo, entidadeId])
}

model User {
  id                         String    @id @default(cuid())
  schoolId                   String?
  email                      String    @unique
  openaiApiKey               String?
  plan                       String    @default("starter")
  aiUsage                    Int       @default(0)
  createdAt                  DateTime  @default(now())
  ativo                      Boolean   @default(true)
  lastLoginAt                DateTime?
  nome                       String
  passwordHash               String
  role                       UserRole  @default(ADMIN)
  updatedAt                  DateTime  @updatedAt
  username                   String?   @unique
  densidade                  String?   @default("comfortable")
  telefone                   String?
  temaPreferido              String?   @default("light")
  dashboardCards             Json?
  dashboardCardsOrder        Json?
  dashboardInsightsFrequency String?   @default("weekly")
  dashboardInsightsDismissed Json?
  dashboardInsightsEnabled   Boolean   @default(true)
  dashboardInsightsLimit     Int       @default(3)

  school         School?         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  aiAuditLogs    AiAuditLog[]
  aiChatSessions AiChatSession[]

  @@index([schoolId])
  @@index([email])
  @@index([username])
  @@index([role])
  @@index([ativo])
}

model ProfessorCurso {
  id          String   @id @default(cuid())
  professorId String
  cursoId     String
  createdAt   DateTime @default(now())

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  curso     Curso     @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@unique([professorId, cursoId])
  @@index([professorId])
  @@index([cursoId])
}

model TurmaProfessorHistorico {
  id          String    @id @default(cuid())
  turmaId     String
  professorId String
  dataInicio  DateTime
  dataFim     DateTime?
  motivoTroca String?
  observacoes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  turma     Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  professor Professor @relation(fields: [professorId], references: [id], onDelete: Restrict)

  @@index([turmaId])
  @@index([professorId])
  @@index([dataInicio])
  @@index([dataFim])
}

model SystemSetting {
  id             String         @id @default("default")
  aiProviderMode AiProviderMode @default(PLATFORM)
  openaiApiKey   String?
  aiMonthlyLimit Int            @default(1000)
  aiUsageCount   Int            @default(0)
  aiUsageResetAt DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model UserInvite {
  id        String    @id @default(cuid())
  schoolId  String?
  email     String
  role      UserRole  @default(SECRETARIA)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model AiAuditLog {
  id        String   @id @default(cuid())
  userId    String
  message   String
  intent    String
  response  String
  executed  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([intent])
  @@index([createdAt])
}

model AiChatSession {
  id        String          @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  AiChatMessage[]
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AiChatMessage {
  id         String          @id @default(cuid())
  sessionId  String
  role       ChatMessageRole
  content    String
  intent     String?
  confidence Float?
  executed   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  session    AiChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model FinanceAuditEvent {
  id          String   @id @default(cuid())
  schoolId    String
  eventType   String
  source      String
  status      String
  referenceId String?
  message     String
  payload     Json?
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([eventType])
  @@index([source])
  @@index([status])
  @@index([createdAt])
}

model Disciplina {
  id        String   @id @default(cuid())
  schoolId  String
  nome      String
  codigo    String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turmas     TurmaDisciplina[]
  avaliacoes Avaliacao[]
  aulas      AulaRegistro[]

  @@unique([schoolId, nome])
  @@index([schoolId])
  @@index([ativo])
}

model TurmaDisciplina {
  id           String   @id @default(cuid())
  schoolId     String
  turmaId      String
  disciplinaId String
  createdAt    DateTime @default(now())

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turma      Turma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@unique([turmaId, disciplinaId])
  @@index([schoolId])
  @@index([turmaId])
  @@index([disciplinaId])
}

model Avaliacao {
  id           String   @id @default(cuid())
  schoolId     String
  turmaId      String
  disciplinaId String
  professorId  String?
  titulo       String
  descricao    String?
  peso         Decimal? @db.Decimal(5, 2)
  dataAvaliacao DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turma      Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina Disciplina  @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  professor  Professor?  @relation(fields: [professorId], references: [id], onDelete: SetNull)
  notas      NotaAvaliacao[]

  @@index([schoolId])
  @@index([turmaId])
  @@index([disciplinaId])
  @@index([dataAvaliacao])
}

model NotaAvaliacao {
  id          String   @id @default(cuid())
  schoolId    String
  avaliacaoId String
  matriculaId String
  nota        Decimal  @db.Decimal(5, 2)
  observacao  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  avaliacao Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  matricula Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  @@unique([avaliacaoId, matriculaId])
  @@index([schoolId])
  @@index([matriculaId])
}

model AulaRegistro {
  id           String    @id @default(cuid())
  schoolId     String
  turmaId      String
  disciplinaId String
  titulo       String?
  conteudo     String?
  dataAula     DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  turma      Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina Disciplina  @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  presencas  PresencaAula[]

  @@index([schoolId])
  @@index([turmaId])
  @@index([disciplinaId])
  @@index([dataAula])
}

model PresencaAula {
  id          String   @id @default(cuid())
  schoolId    String
  aulaId      String
  matriculaId String
  presente    Boolean  @default(true)
  observacao  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school    School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  aula      AulaRegistro @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  matricula Matricula   @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  @@unique([aulaId, matriculaId])
  @@index([schoolId])
  @@index([matriculaId])
}

model EscolaSettings {
  id                    String   @id
  schoolId              String   @unique
  nomeEscola            String
  cnpj                  String?
  email                 String?
  telefone              String?
  whatsapp              String?
  endereco              String?
  logoUrl               String?
  corPrimaria           String?  @default("#111111")
  diaVencimentoPadrao   Int?     @default(10)
  multaAtrasoPercentual Decimal? @db.Decimal(10, 2)
  jurosMensalPercentual Decimal? @db.Decimal(10, 2)
  gerarMensalidadeAuto  Boolean  @default(false)
  metodoPagamentoPadrao String?
  notificarNovoAluno    Boolean  @default(true)
  notificarPagamento    Boolean  @default(true)
  notificarAtraso       Boolean  @default(true)
  enviarLembreteAuto    Boolean  @default(false)
  temaPadrao            String?  @default("light")
  densidade             String?  @default("comfortable")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  metaMensal            Decimal? @db.Decimal(10, 2)
  billingProvider       String?  @default("asaas")
  asaasApiKey           String?
  asaasWalletId         String?
  asaasEnvironment      String?  @default("sandbox")
  defaultChargeMethod   String?  @default("boleto")
  billingEnabled        Boolean  @default(false)
  autoGenerateBoleto    Boolean  @default(false)
  autoSendBoletoWhatsApp Boolean @default(false)
  reguaCobrancaDias          String?  @default("1,3,7")
  suspenderAposInadimplenciaDias Int  @default(30)
  subscriptionInadimplenciaAction String @default("SUSPENDER")
  subscriptionInadimplenciaDias Int @default(45)
  openaiApiKey              String?
  aiMonthlyLimitOverride    Int?
  aiUsageCount              Int      @default(0)
  aiUsageResetAt           DateTime @default(now())
  twilioAccountSid         String?
  twilioAuthToken          String?
  twilioWhatsAppFrom       String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

enum StatusAluno {
  ATIVO
  INATIVO
  TRANCADO
  ARQUIVADO
}

enum StatusMatricula {
  ATIVA
  TRANCADA
  CANCELADA
  CONCLUIDA
}

enum StatusPagamento {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum TipoEvento {
  GERAL
  REUNIAO
  PROVA
  REPOSICAO
  FERIADO
  LEMBRETE
}

enum OrigemEvento {
  MANUAL
  AUTOMATICO
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum TipoNotificacao {
  NOVO_ALUNO
  NOVA_MATRICULA
  PAGAMENTO_CONFIRMADO
  PAGAMENTO_ATRASADO
  MATRICULA_CANCELADA
  SISTEMA
  PAGAMENTO
}

enum TipoAlunoRegistro {
  OCORRENCIA
  ADVERTENCIA
  OBSERVACAO
}

enum EntidadeNotificacao {
  ALUNO
  MATRICULA
  PAGAMENTO
  TURMA
  CURSO
  PROFESSOR
  SISTEMA
}

enum UserRole {
  ADMIN
  FINANCEIRO
  SECRETARIA
  PROFESSOR
  SUPER_ADMIN
}

enum AiProviderMode {
  PLATFORM
  CUSTOM
}


model AlunoDocumento {
  id        String   @id @default(cuid())
  alunoId   String
  nome      String
  tipo      String
  url       String
  tamanho   Int?
  createdAt DateTime @default(now())
  aluno     Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@index([alunoId])
  @@index([tipo])
}

model AlunoStatusHistorico {
  id         String   @id @default(cuid())
  alunoId    String
  statusDe   String
  statusPara String
  motivo     String?
  criadoPor  String?
  createdAt  DateTime @default(now())
  aluno      Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@index([alunoId])
  @@index([createdAt])
}

model AlunoRegistro {
  id        String            @id @default(cuid())
  schoolId  String
  alunoId   String
  tipo      TipoAlunoRegistro
  titulo    String
  descricao String?
  gravidade String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  aluno  Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([alunoId])
  @@index([tipo])
  @@index([createdAt])
}

enum IncidentSeverity {
  INFO
  WARNING
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum IncidentCategory {
  FINANCE
  ACADEMIC
  ENROLLMENT
  SYSTEM
}

model OperationalIncident {
  id                 String            @id @default(cuid())
  schoolId           String
  playbookCode       String?
  dedupeKey          String
  category           IncidentCategory
  severity           IncidentSeverity
  status             IncidentStatus    @default(OPEN)
  title              String
  description        String            @db.Text
  problemStatement   String            @db.Text
  suggestedActions   Json
  impactHint         String?
  contextJson        Json?
  lastDetectedAt     DateTime          @default(now())
  lastNotifiedAt     DateTime?
  acknowledgedAt     DateTime?
  acknowledgedById   String?
  resolvedAt         DateTime?
  resolvedById       String?
  dismissedAt        DateTime?
  dismissedById      String?
  dismissReason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, dedupeKey])
  @@index([schoolId, status])
  @@index([schoolId, severity])
  @@index([lastDetectedAt])
}

model OperationalPlaybook {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  active         Boolean  @default(true)
  definitionJson Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  runs OperationalPlaybookRun[]

  @@index([active])
}

model OperationalPlaybookRun {
  id           String   @id @default(cuid())
  schoolId     String
  playbookId   String
  playbookCode String
  status       String
  message      String?
  detailJson   Json?
  createdAt    DateTime @default(now())

  school   School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  playbook OperationalPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([playbookId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}
