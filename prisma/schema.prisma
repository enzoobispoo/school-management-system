  @@index([tipo])
}

model AlunoStatusHistorico {
  id         String   @id @default(cuid())
  alunoId    String
  statusDe   String
  statusPara String
  motivo     String?
  criadoPor  String?
  createdAt  DateTime @default(now())
  aluno      Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)

