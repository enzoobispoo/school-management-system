  @@index([schoolId])
  @@index([avaliacaoId, createdAt])
}

model JogoParticipante {
  id            String        @id @default(cuid())
  schoolId      String
  sessaoId      String
  nome          String
  avatarEmoji   String        @default("🎓")
  score         Decimal       @default(0) @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sessao        JogoSessao    @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  respostas     JogoResposta[]

  @@index([schoolId])
  @@index([sessaoId, createdAt])
}

model JogoResposta {
  id             String               @id @default(cuid())
  schoolId       String
  participanteId String
  questaoId      String
  alternativaId  String?
  correta        Boolean
  pontos         Decimal              @default(0) @db.Decimal(10, 2)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  school         School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  participante   JogoParticipante     @relation(fields: [participanteId], references: [id], onDelete: Cascade)
  questao        AvaliacaoQuestao     @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  alternativa    AvaliacaoAlternativa? @relation(fields: [alternativaId], references: [id], onDelete: SetNull)

  @@unique([participanteId, questaoId])
  @@index([schoolId])
  @@index([questaoId, createdAt])
}

model NotaAvaliacao {
