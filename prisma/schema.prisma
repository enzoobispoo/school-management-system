enum IncidentSeverity {
  INFO
  WARNING
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum IncidentCategory {
  FINANCE
  ACADEMIC
  ENROLLMENT
  SYSTEM
}

model OperationalIncident {
  id                 String            @id @default(cuid())
  schoolId           String
  playbookCode       String?
  dedupeKey          String
  category           IncidentCategory
  severity           IncidentSeverity
  status             IncidentStatus    @default(OPEN)
  title              String
  description        String            @db.Text
  problemStatement   String            @db.Text
  suggestedActions   Json
  impactHint         String?
  contextJson        Json?
  lastDetectedAt     DateTime          @default(now())
  lastNotifiedAt     DateTime?
  acknowledgedAt     DateTime?
  acknowledgedById   String?
  resolvedAt         DateTime?
  resolvedById       String?
  dismissedAt        DateTime?
  dismissedById      String?
  dismissReason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, dedupeKey])
  @@index([schoolId, status])
  @@index([schoolId, severity])
  @@index([lastDetectedAt])
}

model OperationalPlaybook {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  active         Boolean  @default(true)
  definitionJson Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  runs OperationalPlaybookRun[]

  @@index([active])
}

model OperationalPlaybookRun {
  id           String   @id @default(cuid())
  schoolId     String
  playbookId   String
  playbookCode String
  status       String
  message      String?
  detailJson   Json?
  createdAt    DateTime @default(now())

  school   School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  playbook OperationalPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([playbookId])
  @@index([createdAt])
}

model SchoolChatThread {
  id            String    @id @default(cuid())
  schoolId      String
  kind          SchoolChatThreadKind   @default(DIRECT)
  /** Par ordenado userId:userId para DM na mesma escola (único por escola). */
  dmKey         String?
  /** Nome do grupo (obrigatório quando kind = GROUP). */
  title         String?
  /** Criador do grupo (gestor); mensagens “somente gestor” usam esta referência. */
  ownerUserId   String?
  writePolicy   SchoolChatWritePolicy @default(ALL_MEMBERS)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school       School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  owner        User?                   @relation("SchoolChatThreadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  participants SchoolChatParticipant[]
  messages     SchoolChatMessage[]

  @@unique([schoolId, dmKey])
  @@index([schoolId, lastMessageAt])
  @@index([schoolId, kind])
}

model SchoolChatParticipant {
  id         String    @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime?
  /** Fixação só para este usuário; conversas fixadas sobem na lista. */
  pinnedAt   DateTime?
  /** Ocultar conversa só para este usuário (estilo “apagar pra mim”). Nova mensagem reabre para os destinatários. */
  hiddenAt   DateTime?
  /** IDs de mensagens ocultas só para este usuário (“apagar mensagem para mim”). */
  hiddenMessageIds String[] @default([])
  createdAt  DateTime  @default(now())

  thread SchoolChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
  @@index([userId, pinnedAt])
  @@index([userId, hiddenAt])
}

model SchoolChatMessage {
  id             String    @id @default(cuid())
  threadId       String
  senderUserId   String
  body           String    @db.Text
  attachmentUrl  String?
  attachmentName String?
  editedAt       DateTime?
  /** Mensagem fixada na conversa (visível para todos). */
  pinnedAt       DateTime?
  /** Apagada para todos os participantes (conteúdo removido). */
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  thread SchoolChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User             @relation("SchoolChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([threadId, pinnedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}
